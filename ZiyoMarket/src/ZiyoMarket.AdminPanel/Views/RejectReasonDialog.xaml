<Window x:Class="ZiyoMarket.AdminPanel.Views.RejectReasonDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Rad etish sababi"
        Width="440" Height="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="White">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Rad etish sababini kiriting"
                   FontSize="16" FontWeight="SemiBold" Margin="0,0,0,16"/>

        <TextBox Grid.Row="1"
                 x:Name="ReasonTextBox"
                 materialDesign:HintAssist.Hint="Misol: Chek ko'rinmayapti, noto'g'ri miqdor, boshqa karta..."
                 materialDesign:HintAssist.IsFloating="True"
                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                 TextWrapping="Wrap"
                 AcceptsReturn="False"
                 MaxLength="300"
                 VerticalScrollBarVisibility="Auto"
                 Margin="0,0,0,16"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Bekor qilish"
                    Style="{StaticResource MaterialDesignFlatButton}"
                    Click="Cancel_Click" Margin="0,0,8,0"/>
            <Button Content="Rad etish"
                    Style="{StaticResource MaterialDesignRaisedButton}"
                    Background="#C62828"
                    Foreground="White"
                    Click="Confirm_Click"/>
        </StackPanel>
    </Grid>
</Window>
