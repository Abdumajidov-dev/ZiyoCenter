<UserControl x:Class="ZiyoMarket.AdminPanel.Views.NotificationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Bildirishnomalar" FontSize="26" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryHueDarkBrush}"/>
                    <Border Background="#F44336" CornerRadius="12" Padding="8,3"
                            Margin="12,0,0,0" VerticalAlignment="Center"
                            Visibility="{Binding UnreadCount, Converter={StaticResource NullToVisibilityConverter}}">
                        <TextBlock Text="{Binding UnreadCount}" Foreground="White"
                                   FontSize="12" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
                <TextBlock Text="To'lov cheklari va tizim xabarlari"
                           FontSize="13" Foreground="Gray" Margin="0,2,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <CheckBox Content="Faqat to'lovlar"
                          IsChecked="{Binding ShowOnlyPayments}"
                          Margin="0,0,16,0" VerticalAlignment="Center"
                          Style="{StaticResource MaterialDesignCheckBox}"/>
                <Button Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding LoadCommand}"
                        Padding="14,6">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center"/>
                        <TextBlock Text="Yangilash" Margin="6,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Info banner -->
        <Border Grid.Row="1" Background="#FFF8E1" CornerRadius="8" Padding="16,12"
                Margin="0,0,0,16" BorderBrush="#FFE082" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <materialDesign:PackIcon Kind="InformationOutline" Width="20" Height="20"
                                         Foreground="#F57F17" VerticalAlignment="Center"/>
                <TextBlock Margin="10,0,0,0" VerticalAlignment="Center" FontSize="13"
                           Foreground="#5D4037" TextWrapping="Wrap">
                    Mijoz to'lov chekini yuborganda bu yerda bildirishnoma tushadi.
                    Chekni ko'rib, <Bold>Tasdiqlash</Bold> yoki <Bold>Rad etish</Bold> tugmasini bosing.
                    Tasdiqlangandan keyin buyurtma <Bold>Tasdiqlandi</Bold> holatiga o'tadi.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Notifications list -->
        <Grid Grid.Row="2">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Notifications}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <materialDesign:Card Margin="0,0,0,10"
                                                 Padding="0">
                                <Grid>
                                    <!-- Left colored stripe -->
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" CornerRadius="4,0,0,4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#FF9800"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                        <Setter Property="Background" Value="#BDBDBD"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>

                                    <Grid Grid.Column="1" Margin="16,14,16,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon -->
                                        <Border Width="44" Height="44" CornerRadius="22"
                                                VerticalAlignment="Center" Margin="0,0,14,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#FFF3E0"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                            <Setter Property="Background" Value="#F5F5F5"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <materialDesign:PackIcon Kind="ReceiptTextCheck"
                                                                     Width="24" Height="24"
                                                                     HorizontalAlignment="Center"
                                                                     VerticalAlignment="Center">
                                                <materialDesign:PackIcon.Style>
                                                    <Style TargetType="materialDesign:PackIcon">
                                                        <Setter Property="Foreground" Value="#FF9800"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                                <Setter Property="Foreground" Value="#9E9E9E"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </materialDesign:PackIcon.Style>
                                            </materialDesign:PackIcon>
                                        </Border>

                                        <!-- Title + Message -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="Bold" FontSize="14">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#212121"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                                    <Setter Property="Foreground" Value="#757575"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <Border Background="#FF9800" CornerRadius="10"
                                                        Padding="6,2" Margin="8,0,0,0"
                                                        VerticalAlignment="Center"
                                                        Visibility="{Binding IsRead, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <!-- inverted: show when NOT read -->
                                                </Border>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Message}"
                                                       FontSize="13" Foreground="#616161"
                                                       TextWrapping="Wrap" MaxWidth="500"/>
                                            <TextBlock Text="{Binding CreatedAt}"
                                                       FontSize="11" Foreground="#9E9E9E"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <!-- Action Button -->
                                        <Button Grid.Column="2"
                                                Style="{StaticResource MaterialDesignRaisedButton}"
                                                Background="#FF9800"
                                                VerticalAlignment="Center"
                                                Padding="16,8"
                                                Command="{Binding DataContext.OpenOrderCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}">
                                            <StackPanel Orientation="Horizontal">
                                                <materialDesign:PackIcon Kind="Eye" Width="16" Height="16"
                                                                         Foreground="White"
                                                                         VerticalAlignment="Center"/>
                                                <TextBlock Text="Ko'rish" Foreground="White"
                                                           Margin="6,0,0,0" VerticalAlignment="Center"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Grid>
                            </materialDesign:Card>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding Notifications.Count, Converter={StaticResource InverseNullToVisibilityConverter}}">
                <materialDesign:PackIcon Kind="BellOff" Width="64" Height="64"
                                         Foreground="#BDBDBD" HorizontalAlignment="Center"/>
                <TextBlock Text="Bildirishnomalar yo'q" FontSize="16" Foreground="#9E9E9E"
                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
                <TextBlock Text="Yangi to'lov cheklari kelganda bu yerda ko'rinadi"
                           FontSize="13" Foreground="#BDBDBD"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- Loading -->
            <Border Background="#80FFFFFF"
                    Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 Width="48" Height="48" IsIndeterminate="True"/>
                    <TextBlock Text="Yuklanmoqda..." Margin="0,10,0,0"
                               HorizontalAlignment="Center" Foreground="Gray"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
