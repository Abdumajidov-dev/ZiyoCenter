<Window x:Class="ZiyoMarket.AdminPanel.Views.CustomerDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Mijoz ma'lumotlari"
        Width="780" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="StatCard" TargetType="materialDesign:Card">
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,4,0,2"/>
        </Style>
        <Style x:Key="StatLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="Gray"/>
        </Style>
        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER BANNER ===== -->
        <Border Grid.Row="0" Height="160">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1565C0" Offset="0"/>
                    <GradientStop Color="#0288D1" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid Margin="32,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Avatar -->
                <Border Grid.Column="0" Width="90" Height="90" CornerRadius="45"
                        BorderThickness="3" BorderBrush="White"
                        VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#42A5F5" Offset="0"/>
                            <GradientStop Color="#1E88E5" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock x:Name="InitialsText"
                               Foreground="White" FontWeight="Bold" FontSize="28"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- Name & Phone -->
                <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="FullNameText"
                               Foreground="White" FontSize="22" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <materialDesign:PackIcon Kind="Phone" Width="16" Height="16"
                                                 Foreground="#B3E5FC" VerticalAlignment="Center"/>
                        <TextBlock x:Name="PhoneText"
                                   Foreground="#B3E5FC" FontSize="14" Margin="6,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <materialDesign:PackIcon Kind="CalendarAccount" Width="15" Height="15"
                                                 Foreground="#B3E5FC" VerticalAlignment="Center"/>
                        <TextBlock x:Name="JoinDateText"
                                   Foreground="#B3E5FC" FontSize="12" Margin="6,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Status Badge -->
                <Border Grid.Column="2" x:Name="StatusBadge"
                        CornerRadius="20" Padding="16,8"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="8" Height="8"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock x:Name="StatusText" FontSize="14"
                                   FontWeight="SemiBold" Foreground="White"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ===== BODY ===== -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,20,28,8">

                <!-- Stats Row -->
                <TextBlock Text="Statistika" FontSize="16" FontWeight="SemiBold"
                           Margin="0,0,0,12"/>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Total Orders -->
                    <materialDesign:Card Grid.Column="0" Style="{StaticResource StatCard}">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="Receipt" Width="24" Height="24"
                                                     Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock x:Name="TotalOrdersText"
                                       Style="{StaticResource StatValue}"
                                       Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                            <TextBlock Text="Buyurtmalar" Style="{StaticResource StatLabel}"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Total Spent -->
                    <materialDesign:Card Grid.Column="1" Style="{StaticResource StatCard}">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="TrendingUp" Width="24" Height="24"
                                                     Foreground="#1565C0"/>
                            <TextBlock x:Name="TotalSpentText"
                                       Style="{StaticResource StatValue}"
                                       Foreground="#1565C0"/>
                            <TextBlock Text="Jami sarfladi" Style="{StaticResource StatLabel}"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Cashback Balance -->
                    <materialDesign:Card Grid.Column="2" Style="{StaticResource StatCard}">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="CashMultiple" Width="24" Height="24"
                                                     Foreground="#E65100"/>
                            <TextBlock x:Name="CashbackText"
                                       Style="{StaticResource StatValue}"
                                       Foreground="#E65100"/>
                            <TextBlock Text="Cashback balansi" Style="{StaticResource StatLabel}"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Cashback Earned -->
                    <materialDesign:Card Grid.Column="3"
                                         Style="{StaticResource StatCard}"
                                         Margin="0">
                        <StackPanel>
                            <materialDesign:PackIcon Kind="StarCircle" Width="24" Height="24"
                                                     Foreground="#2E7D32"/>
                            <TextBlock x:Name="CashbackEarnedText"
                                       Style="{StaticResource StatValue}"
                                       Foreground="#2E7D32"/>
                            <TextBlock Text="Jami cashback" Style="{StaticResource StatLabel}"/>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>

                <!-- Personal Info + Photo -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="260"/>
                    </Grid.ColumnDefinitions>

                    <!-- Info -->
                    <materialDesign:Card Grid.Column="0" Padding="20" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Shaxsiy ma'lumotlar" FontSize="15"
                                       FontWeight="SemiBold" Margin="0,0,0,14"/>

                            <TextBlock Text="Ism Familiya" Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="DetailFullName" Style="{StaticResource InfoValue}"/>

                            <TextBlock Text="Telefon raqami" Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="DetailPhone" Style="{StaticResource InfoValue}"/>

                            <TextBlock Text="Manzil" Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="DetailAddress" Style="{StaticResource InfoValue}"
                                       TextWrapping="Wrap"/>

                            <TextBlock Text="Oxirgi buyurtma" Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="LastOrderText" Style="{StaticResource InfoValue}"/>

                            <TextBlock Text="Yangilangan sana" Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="UpdatedAtText" Style="{StaticResource InfoValue}"
                                       Margin="0"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Photo / Avatar Card -->
                    <materialDesign:Card Grid.Column="1" Padding="20">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="Profil rasmi" FontSize="15" FontWeight="SemiBold"
                                       Margin="0,0,0,16" HorizontalAlignment="Center"/>

                            <!-- Large Avatar -->
                            <Border Width="140" Height="140" CornerRadius="70"
                                    BorderThickness="4" BorderBrush="#E3F2FD"
                                    HorizontalAlignment="Center">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#42A5F5" Offset="0"/>
                                        <GradientStop Color="#1565C0" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock x:Name="BigInitialsText"
                                           Foreground="White" FontWeight="Bold" FontSize="46"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>

                            <TextBlock x:Name="AvatarNameText"
                                       HorizontalAlignment="Center"
                                       FontSize="16" FontWeight="SemiBold"
                                       Margin="0,14,0,4" TextAlignment="Center"/>

                            <TextBlock x:Name="AvatarPhoneText"
                                       HorizontalAlignment="Center"
                                       Foreground="Gray" FontSize="13"
                                       TextAlignment="Center"/>

                            <Border x:Name="AvatarStatusBadge"
                                    CornerRadius="14" Padding="14,6"
                                    Margin="0,12,0,0" HorizontalAlignment="Center">
                                <TextBlock x:Name="AvatarStatusText"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="White"/>
                            </Border>
                        </StackPanel>
                    </materialDesign:Card>
                </Grid>

            </StackPanel>
        </ScrollViewer>

        <!-- ===== ACTION BAR ===== -->
        <Border Grid.Row="2"
                Background="White"
                BorderThickness="0,1,0,0"
                BorderBrush="#E0E0E0"
                Padding="28,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="InformationOutline" Width="16" Height="16"
                                             Foreground="Gray" VerticalAlignment="Center"/>
                    <TextBlock x:Name="FooterInfoText"
                               Foreground="Gray" FontSize="12" Margin="6,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- Toggle Status -->
                    <Button x:Name="ToggleStatusButton"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Click="ToggleStatusButton_Click"
                            Margin="0,0,12,0"
                            Padding="16,8" Height="40">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon x:Name="ToggleIcon"
                                                     Kind="AccountCheck" Width="18" Height="18"
                                                     VerticalAlignment="Center"/>
                            <TextBlock x:Name="ToggleStatusText"
                                       Margin="6,0,0,0" VerticalAlignment="Center"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <!-- Promote to Admin -->
                    <Button x:Name="PromoteButton"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#1565C0"
                            Click="PromoteButton_Click"
                            Padding="16,8" Height="40">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ShieldAccount" Width="18" Height="18"
                                                     Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text="Admin qilish" Foreground="White"
                                       Margin="6,0,0,0" VerticalAlignment="Center"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <!-- Close -->
                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Click="CloseButton_Click"
                            Margin="12,0,0,0" Padding="16,8" Height="40">
                        <TextBlock Text="Yopish" FontWeight="SemiBold"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
