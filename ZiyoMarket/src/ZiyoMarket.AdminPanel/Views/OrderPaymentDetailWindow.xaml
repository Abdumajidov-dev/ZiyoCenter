<Window x:Class="ZiyoMarket.AdminPanel.Views.OrderPaymentDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="To'lov tasdiqlash"
        Width="1000" Height="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinWidth="800" MinHeight="550"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>
        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="Gray"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>
        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0" Padding="28,18">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#E65100" Offset="0"/>
                    <GradientStop Color="#FF9800" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Width="50" Height="50" CornerRadius="25"
                        Background="#40FFFFFF" VerticalAlignment="Center"
                        Margin="0,0,16,0">
                    <materialDesign:PackIcon Kind="ReceiptTextCheck" Width="26" Height="26"
                                             Foreground="White"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="HeaderOrderNumber" Foreground="White"
                               FontSize="20" FontWeight="Bold"/>
                    <TextBlock x:Name="HeaderCustomerName" Foreground="#FFE0B2"
                               FontSize="13" Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                    <Border CornerRadius="20" Padding="16,8" Background="#40FFFFFF">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ClockAlert" Width="16" Height="16"
                                                     Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text="Tasdiqlash kutilmoqda" Foreground="White"
                                       FontSize="13" FontWeight="SemiBold" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Border>
                    <TextBlock x:Name="HeaderAmount" Foreground="White"
                               FontSize="22" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== BODY ===== -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Order info + items -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="16,16,8,16">
                <StackPanel>

                    <!-- Customer Info -->
                    <materialDesign:Card Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Mijoz ma'lumotlari" Style="{StaticResource SectionTitle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Ism Familiya" Style="{StaticResource InfoLabel}"/>
                                    <TextBlock x:Name="CustName" Style="{StaticResource InfoValue}"/>
                                    <TextBlock Text="Telefon" Style="{StaticResource InfoLabel}"/>
                                    <TextBlock x:Name="CustPhone" Style="{StaticResource InfoValue}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Yetkazib berish" Style="{StaticResource InfoLabel}"/>
                                    <TextBlock x:Name="DeliveryType" Style="{StaticResource InfoValue}"/>
                                    <TextBlock Text="Manzil" Style="{StaticResource InfoLabel}"/>
                                    <TextBlock x:Name="DeliveryAddress" Style="{StaticResource InfoValue}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Mijoz izohi" Style="{StaticResource InfoLabel}"/>
                            <TextBlock x:Name="CustomerNotes" Style="{StaticResource InfoValue}"
                                       TextWrapping="Wrap" Margin="0"/>
                        </StackPanel>
                    </materialDesign:Card>

                    <!-- Order Items -->
                    <materialDesign:Card Padding="18" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="Buyurtma tarkibi" Style="{StaticResource SectionTitle}"/>
                            <DataGrid x:Name="ItemsGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      HorizontalGridLinesBrush="#F0F0F0"
                                      RowHeight="44" FontSize="13">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Mahsulot" Width="*"
                                                        Binding="{Binding ProductName}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="Margin" Value="4,0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Soni" Width="70"
                                                        Binding="{Binding Quantity}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="HorizontalAlignment" Value="Center"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="Narx" Width="130"
                                                        Binding="{Binding FormattedPrice}">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="VerticalAlignment" Value="Center"/>
                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                <Setter Property="Margin" Value="0,0,8,0"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="Foreground" Value="#1565C0"/>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Total -->
                            <Border BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"
                                    Margin="0,12,0,0" Padding="0,12,0,0">
                                <Grid>
                                    <TextBlock Text="Jami to'lov:" FontSize="15"
                                               FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TotalAmount" HorizontalAlignment="Right"
                                               FontSize="17" FontWeight="Bold"
                                               Foreground="#E65100"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </materialDesign:Card>

                </StackPanel>
            </ScrollViewer>

            <!-- RIGHT: Receipt preview -->
            <Grid Grid.Column="1" Margin="8,16,16,16">
                <materialDesign:Card Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Receipt header -->
                        <Border Grid.Row="0" Background="#FFF8E1" Padding="16,12"
                                BorderThickness="0,0,0,1" BorderBrush="#FFE082">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="FileImage" Width="20" Height="20"
                                                         Foreground="#F57F17"
                                                         VerticalAlignment="Center"/>
                                <TextBlock Text="To'lov cheki" FontSize="14" FontWeight="SemiBold"
                                           Foreground="#E65100" Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- Receipt image / no-receipt state -->
                        <Grid Grid.Row="1">
                            <!-- Receipt image -->
                            <ScrollViewer x:Name="ImageScrollViewer"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Auto"
                                          Visibility="Collapsed">
                                <Image x:Name="ReceiptImage"
                                       Stretch="Uniform"
                                       MaxHeight="400"
                                       Margin="8"/>
                            </ScrollViewer>

                            <!-- PDF / other file -->
                            <StackPanel x:Name="PdfPanel"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <materialDesign:PackIcon Kind="FilePdfBox" Width="80" Height="80"
                                                         Foreground="#F44336"
                                                         HorizontalAlignment="Center"/>
                                <TextBlock Text="PDF fayl" FontSize="16" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" Margin="0,12,0,6"/>
                                <Button x:Name="OpenPdfButton"
                                        Style="{StaticResource MaterialDesignOutlinedButton}"
                                        Click="OpenPdfButton_Click"
                                        Margin="0,8,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="OpenInNew" Width="16" Height="16"
                                                                 VerticalAlignment="Center"/>
                                        <TextBlock Text="Brauzerda ochish" Margin="6,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>

                            <!-- No receipt -->
                            <StackPanel x:Name="NoReceiptPanel"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="FileAlert" Width="64" Height="64"
                                                         Foreground="#BDBDBD"
                                                         HorizontalAlignment="Center"/>
                                <TextBlock Text="Chek yuklanmagan" FontSize="14"
                                           Foreground="#9E9E9E"
                                           HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Grid>

                        <!-- Receipt URL -->
                        <Border Grid.Row="2" Background="#FAFAFA" Padding="12,8"
                                BorderThickness="0,1,0,0" BorderBrush="#E0E0E0">
                            <TextBlock x:Name="ReceiptUrlText" FontSize="11"
                                       Foreground="#9E9E9E" TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                    </Grid>
                </materialDesign:Card>
            </Grid>
        </Grid>

        <!-- ===== ACTION BAR ===== -->
        <Border Grid.Row="2" Background="White"
                BorderThickness="0,1,0,0" BorderBrush="#E0E0E0"
                Padding="24,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <materialDesign:PackIcon Kind="InformationOutline" Width="16" Height="16"
                                             Foreground="Gray" VerticalAlignment="Center"/>
                    <TextBlock x:Name="FooterNote" Foreground="Gray" FontSize="12"
                               Margin="6,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- Reject -->
                    <Button x:Name="RejectButton"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            Foreground="#C62828" BorderBrush="#C62828"
                            Click="RejectButton_Click"
                            Margin="0,0,12,0" Padding="18,10" Height="44">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CloseCircle" Width="18" Height="18"
                                                     VerticalAlignment="Center"/>
                            <TextBlock Text="Rad etish" Margin="6,0,0,0"
                                       VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>

                    <!-- Approve -->
                    <Button x:Name="ApproveButton"
                            Background="#2E7D32"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Click="ApproveButton_Click"
                            Padding="18,10" Height="44">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CheckCircle" Width="18" Height="18"
                                                     Foreground="White" VerticalAlignment="Center"/>
                            <TextBlock Text="To'lovni tasdiqlash" Foreground="White"
                                       Margin="6,0,0,0" VerticalAlignment="Center"
                                       FontWeight="SemiBold" FontSize="14"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource MaterialDesignFlatButton}"
                            Click="CloseButton_Click"
                            Margin="12,0,0,0" Padding="16,10" Height="44">
                        <TextBlock Text="Yopish" FontWeight="SemiBold"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
